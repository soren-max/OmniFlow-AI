# Application
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
APP_NAME=contentops-api
LOG_LEVEL=INFO

# PostgreSQL
DATABASE_URL=postgresql+psycopg://contentops:contentops_password@localhost:5432/contentops
POSTGRES_USER=contentops
POSTGRES_PASSWORD=contentops_password
POSTGRES_DB=contentops
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional LLM provider configuration
# LLM_PROVIDER=mock   → deterministic platform adaptation (no API key required)
# LLM_PROVIDER=deepseek → real LLM-powered generation (requires LLM_API_KEY in .env)
# Do NOT commit LLM_API_KEY to version control.
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=30

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Security
# SECRET_KEY=change-me-to-a-random-secret-key
# API_TOKEN=change-me-to-a-random-api-token
